# ============================================================
# FIX-R EC2 AI Server — Configuration
# Fill in your values here before running setup.sh
# ============================================================

# Your ngrok auth token
# Get it from: https://dashboard.ngrok.com → Your Authtoken
NGROK_AUTH_TOKEN=32rPEBBhdIec0GIxUgOu3UDxDFb_5U9kNs1fpJnsmnJednyCN

# Your ngrok static domain (optional but recommended — keeps URL stable)
# Get it from: https://dashboard.ngrok.com → Domains → Create Domain
# Example: abc-xyz-123.ngrok-free.app
# Leave blank to use a random URL (changes on every restart)
NGROK_STATIC_DOMAIN=am-ai.ngrok.dev

# Your API key (optional — leave blank to auto-generate one)
# If set, this key will be used to authenticate requests from FIX-R to Ollama.
# Must start with: fixr-
# Example: fixr-mysecretkey123
API_KEY=fixr-3CBSansl57rBqzMHlPEUhj0T3ZS_7AgeX6QnYCugNcBshzQSK

# Model to pull automatically during setup (optional)
# Leave blank to be prompted interactively.
# Examples: llama3.2, phi3, mistral, llama3.1:8b, qwen2.5:7b
DEFAULT_MODEL=llama3.2
